# Generated / compiled files
pl_detail.db
pl_data.json
api_data/

# Phase 2 import-run workspaces and database backups
workspaces/
!workspaces/*/templates.json
*.db.bak

# Python
__pycache__/
*.pyc
*.pyo

# Node
node_modules/

# Large data files (keep locally, not in Git)
*.xlsb

# IDE
.vscode/
.idea/

# OS
Thumbs.db
Desktop.ini

# QA / debug artifacts
.playwright-cli/
output/playwright/

# Generated reports may derive from real client data — keep local.
output/reports/

# Knowledge notes generated from data can contain client figures; graph is derived.
knowledge/data/
output/knowledge-graph.json

# Extraction engine — client source files and their raw captures stay local.
# Client financial data must never be committed.
intake/*
!intake/.gitkeep
raw/*
!raw/.gitkeep

# Python packaging metadata from local installs
*.egg-info/

# Phase 2 — per-client import history manifests (may reference client data)
import_history*.json

# Guardian "seen alerts" memory (local only)
output/guardian_state.json

# Multi-client databases (client financial data — keep local, never commit)
clients/
